# Generated output — run the scripts to reproduce
caravan_maribyrnong/
caravan_maribyrnong_zenodo.zip

# Never commit zip archives — all generated/bundled
*.zip

# Local data — not committed
data/

# Local reference material — not part of the codebase
code_to_leverage/

# Archived scripts — no longer part of the active pipeline
archive/

# Internal task tracking — not part of the codebase
tasks/

# One-off build helper — regenerates the ausvic notebooks from code_to_leverage/
_build_ausvic_notebooks.py

# Per-script data caches (deleted to force re-download)
era5land_cache_*.json
silo_cache_*.csv

# Never commit CSVs — all CSV data is generated/downloaded
*.csv

# Never commit shapefile / GIS vector outputs — all generated
*.cpg
*.dbf
*.geojson
*.prj
*.shp
*.shx

# Never commit PNGs — all generated figures
*.png
# ...except figures committed for the README
!outlet_proof.png

# Never commit netCDF data — generated timeseries
*.nc

# GEE ERA5-Land batch exports (downloaded from Google Drive, not committed)
batch*.csv

# GEE part-1 outputs (~2.3 GB of batch CSVs, regenerated by the pipeline)
GEE_part_1_outputs/

# Raw BOM streamflow exports (~226 MB, downloaded, not committed)
bom_exports/

# Large geopackage download cache (~800 MB)
notebooks/mwstr_cache/
*.gpkg

# Assembled Caravan bundle (~101 MB of data) — keep the docs, drop the data
ausvic_caravan_bundle/*
!ausvic_caravan_bundle/README.md
!ausvic_caravan_bundle/LICENSE.txt

# Pipeline stage output dirs — not committed
03_streamflow/
04_caravan_bundle/

# pytest cache
.pytest_cache/

